# ── Squad API ─────────────────────────────────────────────────────────
# Get these from https://dashboard.squadco.com → Settings → API Configuration.
# NEVER commit the real values — this file is a template only.
#
# Sandbox vs live: keep them on the same environment.
#   Sandbox: SQUAD_SECRET_KEY=sandbox_sk_... + SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
#   Live:    SQUAD_SECRET_KEY=sk_live_...    + SQUAD_BASE_URL=https://api-d.squadco.com
# Mixing them (e.g. live key against sandbox URL) returns
# "API key is empty or invalid. Key must start with sandbox_sk_".

SQUAD_SECRET_KEY=
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_MERCHANT_ID=SQUADCO

# "live" forces live mode. "auto" (default) treats any non-empty SECRET as live.
# Set to "mock" to force fallback regardless of secret presence.
SQUAD_MODE=auto

# SMS sender ID — must be pre-registered on the Squad dashboard
# (Settings → SMS Sender IDs). Leave blank to disable SMS delivery (falls back).
SQUAD_SMS_SENDER_ID=

# ── Supabase (durable storage) ─────────────────────────────────────────
# Optional. Without these, the app falls back to a local JSON file
# (data/db.json) on disk. Required on Vercel/Lambda since their FS is read-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Webhook URL (set this in the Squad dashboard, NOT here) ────────────
# Configure in dashboard → API Configuration → Webhook URL:
#   https://<your-domain>/api/squad/webhook
# Squad signs every event with SQUAD_SECRET_KEY using SHA-512 HMAC;
# our handler verifies via the x-squad-signature header.
